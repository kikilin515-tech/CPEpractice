#include <bits/stdc++.h>
using namespace std;

int main()
{
    int a,b;
    while(cin>>a>>b){
        if(a==0&&b==0)return 0;
        int count=0;
        int carry=0;
        while(a||b){ //a或b為0時停止運算
            if(a%10+b&10+carry>=10){
                count++;
                carry=1;
            }else{
                carry=0;
            }
            a/=10;//例如要算555+555，第一次算555—>55->5->0
            b/=10;//555->55->5->0
        }
        if(count==0)cout<<"No carry operation.\n";
        else if(count==1)cout<<"1 carry operation.\n";
        else cout<<count<<"carry operation.\n";
    }
    return 0;
}